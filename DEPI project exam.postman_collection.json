    {
      "name": "questionsss",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the response JSON\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "if (responseData && responseData.results) {\r",
              "    const allowedTypes = ['mcq', 'essay', 'passage'];\r",
              "    \r",
              "    // 2. Filter for valid question types\r",
              "    const validQuestions = responseData.results.filter(q => \r",
              "        allowedTypes.includes(q.type_ans) && q.level && q.subject_semester\r",
              "    );\r",
              "    \r",
              "    // 3. Group questions by their level and semester combination\r",
              "    const groups = {};\r",
              "    validQuestions.forEach(q => {\r",
              "        // Create a unique key combining stage, grade, and semester\r",
              "        const key = `${q.level.stage}_${q.level.grade}_${q.subject_semester}`;\r",
              "        if (!groups[key]) {\r",
              "            groups[key] = [];\r",
              "        }\r",
              "        groups[key].push(q);\r",
              "    });\r",
              "    \r",
              "    // 4. Find the group that has the highest number of matching questions\r",
              "    let bestGroupKey = null;\r",
              "    let maxCount = 0;\r",
              "    \r",
              "    for (const key in groups) {\r",
              "        if (groups[key].length > maxCount) {\r",
              "            maxCount = groups[key].length;\r",
              "            bestGroupKey = key;\r",
              "        }\r",
              "    }\r",
              "    \r",
              "    if (bestGroupKey) {\r",
              "        const uniformQuestions = groups[bestGroupKey];\r",
              "        const sampleQuestion = uniformQuestions[0];\r",
              "        \r",
              "        // 5. Save the matched level ID to an environment variable\r",
              "        const levelId = sampleQuestion.level.id;\r",
              "        pm.environment.set(\"examLevelId\", levelId);\r",
              "        \r",
              "        // 6. Select a subset of these uniform questions (e.g., up to 3)\r",
              "        const subsetQuestions = uniformQuestions.slice(0, 3);\r",
              "        \r",
              "        // 7. Format the payload for the Exam API\r",
              "        const formattedQuestions = subsetQuestions.map((q, index) => {\r",
              "            return {\r",
              "                \"question\": q.id,\r",
              "                \"points\": q.points,\r",
              "                \"display_order\": index + 1,\r",
              "                \"time_limit_minutes\": q.estimated_time_minutes || 5\r",
              "            };\r",
              "        });\r",
              "        \r",
              "        // 8. Save the formatted questions array to an environment variable\r",
              "        pm.environment.set(\"examQuestions\", JSON.stringify(formattedQuestions));\r",
              "        \r",
              "        console.log(`Selected Group: ${bestGroupKey}`);\r",
              "        console.log(`Saved level ID [${levelId}] to {{examLevelId}}`);\r",
              "        console.log(`Saved ${formattedQuestions.length} uniform questions to {{examQuestions}}`);\r",
              "    } else {\r",
              "        console.warn(\"No matching question groups could be determined.\");\r",
              "    }\r",
              "} else {\r",
              "    console.error(\"No results found in the response payload.\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
