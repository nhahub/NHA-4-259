          "script": {
            "exec": [
              "const responseData = pm.response.json();\r",
              "\r",
              "const unusedItem = responseData.find(item => item.is_accepted === false);\r",
              "\r",
              "if (unusedItem) {\r",
              "    const code = unusedItem.code;\r",
              "    \r",
              "    pm.environment.set(\"fetchedCode\", code);\r",
              "    \r",
              "    console.log(\"Successfully saved unused code: \" + code);\r",
              "} else {\r",
              "    console.log(\"No unused codes found in the response.\");\r",
              "}"
